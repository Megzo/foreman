{
  "name": "foreman",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @foreman/shell-main dev",
    "dev:mock": "pnpm --filter @foreman/shell-main dev:mock",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p packages/shell-renderer/tsconfig.json",
    "foreman-dev": "tsx tools/foreman-dev.ts",
    "smoke": "tsx tools/foreman-dev.ts chat \"Reply with exactly: SPIKE_OK\"",
    "e2e": "pnpm --filter @foreman/shell-main run build:app && playwright test"
  },
  "devDependencies": {
    "@foreman/codex-adapter": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
